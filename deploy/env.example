# 复制到项目根目录并重命名为 .env 后使用：docker compose up -d --build
#
# 对外端口：见 docker-compose.yml（默认宿主机 3002 → 前端容器 80；后端 Nest 监听 3002）

# 必填：大模型 API（与 backend/.env.example 说明一致）
OPENAI_API_KEY=

# 可选：兼容 OpenAI 的 Base URL 与模型名
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus

# 可选：构建前端时写入的 API 根路径。使用本仓库 docker-compose 时保持默认 `/` 即可（同域 Nginx 反代）
# VITE_API_BASE_URL=/

# 可选：若后端启用 x-api-key，与 VITE_API_KEY 一致
# VITE_API_KEY=
